<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Garena Auto Clicker"
        android:textColor="#E0E0E0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Auto-click Via app • Homepage"
        android:textColor="#9E9E9E"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvOverlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Overlay: Not Granted"
        android:textColor="#FF5252"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvAccessibilityStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Accessibility: Disabled"
        android:textColor="#FF5252"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnGrantOverlay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Grant Overlay Permission"
        android:backgroundTint="#3D5AFE"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnGrantAccessibility"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Enable Accessibility Service"
        android:backgroundTint="#3D5AFE"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnLaunchOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  Launch Floating Window"
        android:textSize="16sp"
        android:backgroundTint="#43A047"
        android:enabled="false"/>

</LinearLayout>
