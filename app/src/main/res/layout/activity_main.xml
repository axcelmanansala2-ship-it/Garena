<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 Garena Auto Clicker"
        android:textColor="#E0E0E0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart detection — no accessibility needed"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:layout_marginBottom="28dp"/>

    <TextView
        android:id="@+id/tvOverlayStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Overlay: Not Granted"
        android:textColor="#FF5252"
        android:textSize="15sp"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvUsageStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❌ Usage Access: Not Granted"
        android:textColor="#FF5252"
        android:textSize="15sp"
        android:layout_marginBottom="22dp"/>

    <Button
        android:id="@+id/btnGrantOverlay"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="1. Grant Overlay Permission"
        android:backgroundTint="#3D5AFE"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnGrantUsage"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="2. Grant Usage Access (Optional)"
        android:backgroundTint="#3D5AFE"
        android:layout_marginBottom="22dp"/>

    <Button
        android:id="@+id/btnLaunchOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  Launch Floating Window"
        android:textSize="16sp"
        android:backgroundTint="#43A047"
        android:enabled="false"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Only Overlay permission is required.\nUsage Access improves Via detection speed."
        android:textColor="#616161"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
